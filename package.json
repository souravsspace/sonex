{
  "name": "sonex",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "fix": "ultracite fix",
    "check": "ultracite check",
    "clean": "turbo run clean",
    "tauri": "bun --filter desktop tauri",
    "tauri:dev": "bun --filter desktop tauri:dev",
    "tauri:build": "bun --filter desktop tauri:build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "lint-staged": "^16.3.3",
    "turbo": "^2.3.3",
    "ultracite": "7.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  }
}
